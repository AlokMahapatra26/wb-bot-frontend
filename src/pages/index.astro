---
import Layout from '../layouts/Layout.astro';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || import.meta.env.SUPABASE_URL || '';
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || import.meta.env.SUPABASE_ANON_KEY || '';
---
<Layout title="WhatsApp AI Bot Creator">
    <div style="overflow-y: auto; overflow-x: hidden; min-height: 100vh; background: var(--color-surface-dark); color: var(--color-on-dark);">
    <header style="height: 64px; display: flex; align-items: center; justify-content: space-between; padding-left: 24px; padding-right: 24px; background: var(--color-surface-dark); border-bottom: 1px solid var(--color-surface-dark-elevated); position: sticky; top: 0; z-index: 50; backdrop-filter: blur(8px);">
        <span style="font-size: 14px; font-weight: 500; letter-spacing: -0.2px; color: var(--color-on-dark); font-family: var(--font-body);">WhatsApp AI Bot <span style="color: var(--color-primary);">Creator</span></span>
    </header>

    <main class="landing-main">
        <!-- HERO -->
        <div class="landing-hero">
            <div style="display: flex; flex-direction: column;">
                <h1 style="font-family: var(--font-display); font-size: 56px; font-weight: 400; line-height: 1.05; letter-spacing: -1.5px; color: var(--color-on-dark); margin: 0;">Automate your WhatsApp with <em style="font-style: italic; color: var(--color-primary);">intelligence</em></h1>
                <p style="font-family: var(--font-body); font-size: 18px; line-height: 1.6; color: var(--color-on-dark-soft); margin-top: 24px; max-width: 520px;">Define custom AI personalities, instructions, and triggers per contact. Lightweight, database-backed, and beautifully multi-tenant.</p>
            </div>

            <section style="background: var(--color-surface-dark-elevated); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 36px; display: flex; flex-direction: column; gap: 24px; width: 100%;">
                <div style="display: flex; border-bottom: 1px solid rgba(255,255,255,0.08); gap: 8px;" id="auth-tabs">
                    <button type="button" id="tab-login" style="flex: 1; background: transparent; border: none; border-bottom: 2px solid var(--color-primary); border-radius: 0; padding: 14px 8px; color: var(--color-on-dark); font-weight: 500; cursor: pointer; font-size: 14px; transition: all 0.15s; text-align: center; width: 100%; height: auto; font-family: var(--font-body);">Sign In</button>
                    <button type="button" id="tab-register" style="flex: 1; background: transparent; border: none; border-bottom: 2px solid transparent; border-radius: 0; padding: 14px 8px; color: var(--color-on-dark-soft); font-weight: 500; cursor: pointer; font-size: 14px; transition: all 0.15s; text-align: center; width: 100%; height: auto; font-family: var(--font-body);">Create Account</button>
                </div>

                <form id="auth-form" style="display: flex; flex-direction: column; gap: 20px;">
                    <div style="display: flex; flex-direction: column; gap: 6px;">
                        <label for="email" style="font-size: 13px; font-weight: 500; color: var(--color-on-dark);">Email</label>
                        <input type="email" id="email" required placeholder="email@domain.com" style="font-size: 15px; padding: 10px 14px; border-radius: 8px; height: 40px; border: 1px solid rgba(255,255,255,0.12); background: var(--color-surface-dark-soft); color: var(--color-on-dark); outline: none; transition: border-color 0.15s; font-family: var(--font-body); width: 100%; box-sizing: border-box;" />
                    </div>
                    <div style="display: flex; flex-direction: column; gap: 6px;">
                        <label for="password" style="font-size: 13px; font-weight: 500; color: var(--color-on-dark);">Password</label>
                        <div style="position: relative;">
                            <input type="password" id="password" required placeholder="••••••••" minlength="6" style="font-size: 15px; padding: 10px 40px 10px 14px; border-radius: 8px; height: 40px; border: 1px solid rgba(255,255,255,0.12); background: var(--color-surface-dark-soft); color: var(--color-on-dark); outline: none; transition: border-color 0.15s; font-family: var(--font-body); width: 100%; box-sizing: border-box;" />
                            <button type="button" id="toggle-password" aria-label="Show password" style="position: absolute; right: 8px; top: 50%; transform: translateY(-50%); background: transparent; border: none; cursor: pointer; padding: 2px; width: auto; color: var(--color-on-dark-soft); font-size: 16px; line-height: 1;">
                                👁
                            </button>
                        </div>
                    </div>
                    <div style="display: none; flex-direction: column; gap: 6px;" id="confirm-password-group">
                        <label for="confirm-password" style="font-size: 13px; font-weight: 500; color: var(--color-on-dark);">Confirm Password</label>
                        <div style="position: relative;">
                            <input type="password" id="confirm-password" placeholder="••••••••" minlength="6" style="font-size: 15px; padding: 10px 40px 10px 14px; border-radius: 8px; height: 40px; border: 1px solid rgba(255,255,255,0.12); background: var(--color-surface-dark-soft); color: var(--color-on-dark); outline: none; transition: border-color 0.15s; font-family: var(--font-body); width: 100%; box-sizing: border-box;" />
                            <button type="button" id="toggle-confirm-password" aria-label="Show password" style="position: absolute; right: 8px; top: 50%; transform: translateY(-50%); background: transparent; border: none; cursor: pointer; padding: 2px; width: auto; color: var(--color-on-dark-soft); font-size: 16px; line-height: 1;">
                                👁
                            </button>
                        </div>
                    </div>

                    <button type="submit" id="submit-btn" style="background: var(--color-primary); color: var(--color-on-primary); border: none; font-weight: 500; padding: 12px 20px; font-size: 14px; border-radius: 8px; transition: all 0.15s; margin-top: 8px; width: 100%; height: 40px; cursor: pointer; font-family: var(--font-body);">Sign In</button>
                    <div id="feedback-msg" style="font-size: 13px; font-family: var(--font-mono); line-height: 1.625; padding: 12px 16px; border-radius: 8px; display: none;"></div>
                </form>
                <div style="border-top: 1px solid rgba(255,255,255,0.08); padding-top: 16px; display: flex; flex-direction: column; gap: 8px;">
                    <button type="button" id="demo-login-btn" style="background: var(--color-surface-dark-soft); color: var(--color-on-dark); border: 1px solid rgba(255,255,255,0.12); font-weight: 500; padding: 10px 16px; font-size: 13px; border-radius: 8px; width: 100%; height: 40px; cursor: pointer; font-family: var(--font-body); display: flex; align-items: center; justify-content: center; gap: 8px;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                        Try with Demo Account
                    </button>
                    <p style="font-size: 11px; color: var(--color-on-dark-soft); text-align: center; line-height: 1.4;">Demo account has no WhatsApp linked or Gemini API key. You'll need to set those up yourself.</p>
                </div>
            </section>
        </div>

        <div style="display: flex; flex-direction: column; gap: 96px; width: 100%;">
            <div>
                <h3 style="font-size: 12px; font-weight: 500; text-transform: uppercase; letter-spacing: 1.5px; color: var(--color-on-dark-soft); margin-bottom: 24px; display: flex; align-items: center; gap: 8px;">Getting Started</h3>
                <div class="landing-steps">
                    <div class="card-responsive" style="background: var(--color-surface-dark-elevated); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 32px; display: flex; flex-direction: column; gap: 12px;">
                        <span style="font-size: 11px; font-family: var(--font-mono); color: var(--color-on-dark-soft); font-weight: 400; letter-spacing: 0.05em;">01 / REGISTRATION</span>
                        <h4 style="font-family: var(--font-display); font-size: 28px; font-weight: 400; letter-spacing: -0.3px; color: var(--color-on-dark);">Create your account</h4>
                        <p style="font-family: var(--font-body); font-size: 16px; line-height: 1.55; color: var(--color-on-dark-soft);">Sign up in seconds. Each user gets an entirely separate configuration space.</p>
                    </div>
                    <div class="card-responsive" style="background: var(--color-surface-dark-elevated); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 32px; display: flex; flex-direction: column; gap: 12px;">
                        <span style="font-size: 11px; font-family: var(--font-mono); color: var(--color-on-dark-soft); font-weight: 400; letter-spacing: 0.05em;">02 / LINK CHAT</span>
                        <h4 style="font-family: var(--font-display); font-size: 28px; font-weight: 400; letter-spacing: -0.3px; color: var(--color-on-dark);">Scan the QR Code</h4>
                        <p style="font-family: var(--font-body); font-size: 16px; line-height: 1.55; color: var(--color-on-dark-soft);">Scan the generated secure QR code with WhatsApp on your phone to link the bot.</p>
                    </div>
                    <div class="card-responsive" style="background: var(--color-surface-dark-elevated); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 32px; display: flex; flex-direction: column; gap: 12px;">
                        <span style="font-size: 11px; font-family: var(--font-mono); color: var(--color-on-dark-soft); font-weight: 400; letter-spacing: 0.05em;">03 / CUSTOMIZE</span>
                        <h4 style="font-family: var(--font-display); font-size: 28px; font-weight: 400; letter-spacing: -0.3px; color: var(--color-on-dark);">Set JID Rules</h4>
                        <p style="font-family: var(--font-body); font-size: 16px; line-height: 1.55; color: var(--color-on-dark-soft);">Write custom system prompts and assign them to specific phone numbers or groups.</p>
                    </div>
                </div>
            </div>

        </div>

        <footer class="landing-footer">
            <span>&copy; {new Date().getFullYear()} WhatsApp AI Bot Creator. All rights reserved.</span>
            <span>Built with Astro, React, Supabase, and Gemini API.</span>
        </footer>
    </main>
    </div>

    <!-- Expose Supabase credentials safely to client script -->
    <div id="supabase-config" data-url={supabaseUrl} data-key={supabaseAnonKey} style="display: none;"></div>

    <script>
        import { createClient } from '@supabase/supabase-js';

        const configEl = document.getElementById('supabase-config');
        const supabaseUrl = configEl?.dataset.url || '';
        const supabaseAnonKey = configEl?.dataset.key || '';
        const supabase = createClient(supabaseUrl, supabaseAnonKey);

        supabase.auth.getSession().then(({ data: { session } }) => {
            if (session) {
                window.location.href = '/dashboard';
            }
        });

        let activeTab = 'login';

        const tabLogin = document.getElementById('tab-login');
        const tabRegister = document.getElementById('tab-register');
        const submitBtn = document.getElementById('submit-btn');
        const authForm = document.getElementById('auth-form');
        const feedback = document.getElementById('feedback-msg');
        const emailInput = document.getElementById('email') as HTMLInputElement;
        const passwordInput = document.getElementById('password') as HTMLInputElement;
        const confirmPasswordInput = document.getElementById('confirm-password') as HTMLInputElement;
        const confirmPasswordGroup = document.getElementById('confirm-password-group');
        const togglePassword = document.getElementById('toggle-password');
        const toggleConfirmPassword = document.getElementById('toggle-confirm-password');

        function setupEyeToggle(btn: HTMLElement | null, input: HTMLInputElement | null) {
            if (!btn || !input) return;
            btn.addEventListener('click', () => {
                const isPassword = input.type === 'password';
                input.type = isPassword ? 'text' : 'password';
                btn.textContent = isPassword ? '🙈' : '👁';
            });
        }
        setupEyeToggle(togglePassword, passwordInput);
        setupEyeToggle(toggleConfirmPassword, confirmPasswordInput);

        function switchTab(tab) {
            activeTab = tab;
            if (tabLogin) {
                tabLogin.style.borderBottomColor = tab === 'login' ? 'var(--color-primary)' : 'transparent';
                tabLogin.style.color = tab === 'login' ? 'var(--color-on-dark)' : 'var(--color-on-dark-soft)';
            }
            if (tabRegister) {
                tabRegister.style.borderBottomColor = tab === 'register' ? 'var(--color-primary)' : 'transparent';
                tabRegister.style.color = tab === 'register' ? 'var(--color-on-dark)' : 'var(--color-on-dark-soft)';
            }
            if (submitBtn) {
                submitBtn.textContent = tab === 'login' ? 'Sign In' : 'Create Account';
            }
            if (confirmPasswordGroup) {
                confirmPasswordGroup.style.display = tab === 'register' ? 'flex' : 'none';
            }
            if (confirmPasswordInput) {
                confirmPasswordInput.required = tab === 'register';
            }
            if (feedback) {
                feedback.style.cssText = 'font-size: 13px; font-family: var(--font-mono); line-height: 1.625; padding: 12px 16px; border-radius: 8px; display: none;';
                feedback.textContent = '';
            }
        }

        tabLogin?.addEventListener('click', () => switchTab('login'));
        tabRegister?.addEventListener('click', () => switchTab('register'));

        // Demo login
        const demoBtn = document.getElementById('demo-login-btn');
        demoBtn?.addEventListener('click', async () => {
            if (!submitBtn || !feedback) return;
            emailInput.value = 'dummy@gmail.com';
            passwordInput.value = '11223344';
            switchTab('login');
            submitBtn.disabled = true;
            submitBtn.textContent = 'Signing in...';
            try {
                const { data, error } = await supabase.auth.signInWithPassword({ email: 'dummy@gmail.com', password: '11223344' });
                if (error) throw error;
                const session = data.session;
                if (session) {
                    document.cookie = `sb-access-token=${session.access_token}; path=/; max-age=${session.expires_in}; SameSite=Lax`;
                }
                feedback.textContent = 'Demo login success. Redirecting...';
                feedback.style.cssText = 'font-size: 13px; font-family: var(--font-mono); line-height: 1.625; padding: 12px 16px; border-radius: 8px; display: block; background: var(--color-surface-dark-elevated); border: 1px solid rgba(255,255,255,0.1); color: var(--color-on-dark); font-weight: 600;';
                setTimeout(() => window.location.href = '/dashboard', 500);
            } catch (err: any) {
                feedback.textContent = 'Demo login failed: ' + (err.message || 'Unknown error');
                feedback.style.cssText = 'font-size: 13px; font-family: var(--font-mono); line-height: 1.625; padding: 12px 16px; border-radius: 8px; display: block; background: var(--color-surface-dark-elevated); border: 1px solid rgba(255,255,255,0.1); color: var(--color-on-dark);';
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = 'Sign In';
            }
        });

        authForm?.addEventListener('submit', async (e) => {
            e.preventDefault();
            if (!submitBtn || !feedback) return;

            const email = emailInput.value.trim();
            const password = passwordInput.value;

            if (activeTab === 'register') {
                const confirmPassword = confirmPasswordInput?.value || '';
                if (password !== confirmPassword) {
                    feedback.textContent = 'Passwords do not match.';
                    feedback.style.cssText = 'font-size: 13px; font-family: var(--font-mono); line-height: 1.625; padding: 12px 16px; border-radius: 8px; display: block; background: var(--color-surface-dark-elevated); border: 1px solid rgba(255,255,255,0.1); color: #faf9f5;';
                    return;
                }
            }

            feedback.style.cssText = 'font-size: 13px; font-family: var(--font-mono); line-height: 1.625; padding: 12px 16px; border-radius: 8px; display: none;';
            feedback.textContent = '';
            submitBtn.disabled = true;
            submitBtn.textContent = activeTab === 'login' ? 'Signing in...' : 'Creating account...';

            try {
                if (activeTab === 'login') {
                    const { data, error } = await supabase.auth.signInWithPassword({ email, password });
                    if (error) throw error;
                    const session = data.session;
                    if (session) {
                        document.cookie = `sb-access-token=${session.access_token}; path=/; max-age=${session.expires_in}; SameSite=Lax`;
                    }
                    feedback.textContent = 'Success. Redirecting...';
                    feedback.style.cssText = 'font-size: 13px; font-family: var(--font-mono); line-height: 1.625; padding: 12px 16px; border-radius: 8px; display: block; background: var(--color-surface-dark-elevated); border: 1px solid rgba(255,255,255,0.1); color: #faf9f5; font-weight: 600;';
                    setTimeout(() => window.location.href = '/dashboard', 500);
                } else {
                    const { data, error } = await supabase.auth.signUp({ email, password });
                    if (error) throw error;
                    if (data.user && !data.session) {
                        const { data: signInData, error: signInError } = await supabase.auth.signInWithPassword({ email, password });
                        if (signInError) {
                            feedback.textContent = 'Account created! Check your email for a verification link, then sign in.';
                            feedback.style.cssText = 'font-size: 13px; font-family: var(--font-mono); line-height: 1.625; padding: 12px 16px; border-radius: 8px; display: block; background: var(--color-surface-dark-elevated); border: 1px solid rgba(255,255,255,0.1); color: #faf9f5; font-weight: 600;';
                            switchTab('login');
                        } else if (signInData.session) {
                            document.cookie = `sb-access-token=${signInData.session.access_token}; path=/; max-age=${signInData.session.expires_in}; SameSite=Lax`;
                            feedback.textContent = 'Account created! Redirecting...';
                            feedback.style.cssText = 'font-size: 13px; font-family: var(--font-mono); line-height: 1.625; padding: 12px 16px; border-radius: 8px; display: block; background: var(--color-surface-dark-elevated); border: 1px solid rgba(255,255,255,0.1); color: #faf9f5; font-weight: 600;';
                            setTimeout(() => window.location.href = '/dashboard', 500);
                        }
                    } else if (data.session) {
                        document.cookie = `sb-access-token=${data.session.access_token}; path=/; max-age=${data.session.expires_in}; SameSite=Lax`;
                        feedback.textContent = 'Account created! Redirecting...';
                        feedback.style.cssText = 'font-size: 13px; font-family: var(--font-mono); line-height: 1.625; padding: 12px 16px; border-radius: 8px; display: block; background: var(--color-surface-dark-elevated); border: 1px solid rgba(255,255,255,0.1); color: #faf9f5; font-weight: 600;';
                        setTimeout(() => window.location.href = '/dashboard', 500);
                    }
                }
            } catch (err: any) {
                const msg = err.message || 'Authentication error occurred.';
                if (msg.includes('Invalid login credentials')) {
                    feedback.textContent = 'Invalid email or password. If you don\'t have an account, click "Create Account" above.';
                } else if (msg.includes('Email not confirmed')) {
                    feedback.textContent = 'Please verify your email first. Check your inbox for a confirmation link.';
                } else if (msg.includes('User already registered')) {
                    feedback.textContent = 'This email is already registered. Try signing in instead.';
                } else {
                    feedback.textContent = msg;
                }
                feedback.style.cssText = 'font-size: 13px; font-family: var(--font-mono); line-height: 1.625; padding: 12px 16px; border-radius: 8px; display: block; background: var(--color-surface-dark-elevated); border: 1px solid rgba(255,255,255,0.1); color: #faf9f5;';
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = activeTab === 'login' ? 'Sign In' : 'Create Account';
            }
        });
    </script>
</Layout>
